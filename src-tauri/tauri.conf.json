{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesignCode",
  "version": "1.0.0",
  "identifier": "ai.designcode.desktop",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2RUUwMTNEN0Q3QTQ4ClJXUkllbjA5QWU2V0FOUWhDeGtIanhQQTJnWjVMMGE4c0kxbWhYeXdkTitwUUtnUGhEM0hWL1VQCg==",
      "endpoints": [
        "https://github.com/haruhiyuki/DesignCode/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeBuildCommand": "npm run frontend:build",
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DesignCode",
        "width": 1600,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../package.json",
      "../README.md",
      "../app/server/**/*",
      "../app/shared/**/*",
      "resources/runtime/**/*"
    ]
  }
}
